{
  "expo": {
    "name": "UltimateHealth-Admin",
    "slug": "UltimateHealth-Admin",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/ic_uth_admin-playstore.png",
    "scheme": "ultimatehealth-admin",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "androidStatusBar": {
      "backgroundColor": "#00BFFF",
      "barStyle": "light-content"
    },
    "splash": {
      "image": "./assets/images/ic_uth_admin-playstore.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ultimatehealth.admin",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "App requires microphone access to record audio.",
        "NSPhotoLibraryAddUsageDescription": "App needs access to save recordings.",
        "NSPhotoLibraryUsageDescription": "App needs access to select or manage audio files.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "READ_MEDIA_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/ic_launcher_foreground.png",
        "backgroundImage": "./assets/images/ic_launcher_background.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ultimatehealth.admin",
      "versionCode": 18
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ic_uth_admin-playstore.png",
          "imageWidth": 150,
          "borderRadius": 75,
          "resizeMode": "contain",
          "backgroundColor": "#00BFFF",
          "dark": {
            "backgroundColor": "#00BFFF"
          }
        }
      ],

      [
        "expo-audio",
        {
          "microphonePermission": "Allow UltimateHealth to access your microphone."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7ff020da-7d24-40c8-ab5b-42106fa79c2f"
      }
    }
  }
}
